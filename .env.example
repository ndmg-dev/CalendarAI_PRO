# CalendAI PRO — Environment Variables Template
# Copy this file to .env and fill in your actual credentials

# ─── Flask ───────────────────────────────────────────────
# Generate a secret key: python -c "import os; print(os.urandom(24).hex())"
FLASK_SECRET_KEY=your-flask-secret-key-here
FLASK_ENV=development

# ─── Database ───────────────────────────────────────────
# Connection string for your PostgreSQL database (e.g., Supabase)
DATABASE_URL=postgresql://user:password@host:port/dbname

# ─── Google OAuth ────────────────────────────────────────
# Get these from the Google Cloud Console (APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── OpenAI / LLM ───────────────────────────────────────
# Your OpenAI API key and preferred model
OPENAI_API_KEY=sk-your-openai-api-key
LLM_MODEL_NAME=gpt-4o-mini

# ─── Email / Brevo (Optional) ──────────────────────────
# Needed for sending email reminders
BREVO_API_KEY=your-brevo-api-key

# ─── Security ───────────────────────────────────────────
# Used for encrypting sensitive tokens in the database
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# ─── Development Only ───────────────────────────────────
# Set to 1 to allow OAuth over HTTP (testing local)
# Set to 0 or remove for production (enforces HTTPS)
OAUTHLIB_INSECURE_TRANSPORT=1
